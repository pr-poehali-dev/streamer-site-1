{
  "tests": [
    {
      "name": "Register with empty fields returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "username": "", "password": ""},
      "expectedStatus": 400,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with empty credentials returns 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "username": "", "password": ""},
      "expectedStatus": 401,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "Me without token returns 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "me"},
      "expectedStatus": 401,
      "expectedBody": {"ok": false},
      "bodyMatcher": "partial"
    }
  ]
}